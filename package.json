{
  "name": "react-day-picker-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm clean:dist && pnpm build:react-day-picker && pnpm build:packages",
    "build:react-day-picker": "pnpm --filter react-day-picker build",
    "build:packages": "pnpm -r --filter \"@daypicker/*\" build",
    "clean:dist": "rm -rf packages/*/dist",
    "format": "prettier -w \"**/*.{md,mdx,ts,tsx}\"",
    "lint": "biome check",
    "test": "jest --selectProjects examples --selectProjects src --selectProjects packages --selectProjects scripts",
    "test:tz": "TZ=Australia/Adelaide jest --selectProjects examples/timezone",
    "test:build": "jest --selectProjects examples/built",
    "test-watch": "jest --watch",
    "typecheck": "pnpm typecheck:root && pnpm typecheck:packages",
    "typecheck:root": "tsc --project ./tsconfig.json --noEmit",
    "typecheck:packages": "pnpm -r --filter \"@daypicker/*\" typecheck && pnpm --filter react-day-picker typecheck",
    "check:versions": "node ./scripts/check-package-versions.mjs",
    "pack:dry-run": "node ./scripts/npm-pack-dry-run.mjs",
    "release:ci": "pnpm exec tsx ./scripts/release-ci.ts",
    "typecheck-watch": "tsc --project ./tsconfig.json --noEmit --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/cli": "^2.31.0",
    "@date-fns/tz": "^1.4.1",
    "@jest/types": "^30.3.0",
    "@radix-ui/react-select": "^2.2.6",
    "@swc/core": "^1.15.26",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "date-fns": "^4.1.0",
    "date-fns-jalali": "^4.1.0-0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-transform-css": "^6.0.3",
    "mockdate": "^3.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.0",
    "react": "^19.2.5",
    "react-day-picker": "workspace:*",
    "react-dom": "^19.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-css-modules": "^1.0.4"
  },
  "pnpm": {
    "overrides": {
      "@babel/runtime": "7.28.4",
      "ajv@6": "6.15.0",
      "diff": "4.0.4",
      "serialize-javascript": "7.0.5"
    }
  }
}
