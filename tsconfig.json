{
  "extends": "./tsconfig-workspace-base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "jest", "@testing-library/jest-dom", "@types/jest"]
  },
  "include": [
    "src",
    "packages",
    "test",
    "**/*.test.*",
    "examples",
    "scripts/**/*.d.ts",
    "scripts/**/*.d.mts"
  ],
  "exclude": ["website"]
}
